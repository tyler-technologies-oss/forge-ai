{
  "name": "@tylertech/agent-ui-kit",
  "version": "0.0.1",
  "description": "Pre-built Forge component wrappers for Tyler Agent UI - ready-to-use catalog components.",
  "license": "Apache-2.0",
  "author": "Tyler Technologies, Inc.",
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    },
    "./forge": {
      "types": "./dist/forge/index.d.ts",
      "default": "./dist/forge/index.mjs"
    },
    "./forge/catalog": {
      "types": "./dist/forge/catalog.d.ts",
      "default": "./dist/forge/catalog.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": ["./dist"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tyler-technologies-oss/forge-ai.git"
  },
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "vite build",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@tylertech/agent-ui-core": "workspace:^",
    "lit": "catalog:",
    "zod": "^4.0.0"
  },
  "peerDependencies": {
    "@tylertech/forge": "^4.0.0"
  },
  "devDependencies": {
    "@repo/prettier-config": "workspace:",
    "@types/node": "catalog:",
    "@tylertech/forge": "catalog:",
    "eslint": "catalog:",
    "rimraf": "catalog:",
    "typescript": "~5.9.3",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:"
  }
}
